# Moon Studio — Environment Variables
# העתק קובץ זה ל-.env ומלא את הערכים
# ⚠️ לא לעשות commit ל-.env עם ערכים אמיתיים

# Supabase CRM
# מצא ב: supabase.com → הפרויקט שלך → Settings → API
SUPABASE_URL=https://[your-project-id].supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Gmail / Google Calendar — מוגדר דרך MCP, לא כאן
# ראה tools/gmail.md ו-tools/calendar.md
