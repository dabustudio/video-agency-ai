# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
.env

# Environment
.env
.env.local
.env.*.local

# Output artifacts (generated at runtime) — PDFs, raw video, large files
output/**/*.pdf
output/**/*.mp4
output/**/*.mov
output/**/raw/
# Track folder structure and starter JSON files
!output/
!output/**/.gitkeep
!output/projects/leads.json
!output/marketing/outreach_log/outreach_log.json
!output/production/schedule_template.json
!output/coo/improvement_log.json
!output/growth/tech/.gitkeep
!output/growth/business/.gitkeep
!output/coo/.gitkeep
!output/supervisor/.gitkeep

# API keys / secrets
secrets.json
*.key
*.pem

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Node (if any tooling uses it)
node_modules/
